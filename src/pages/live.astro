---
/**
 * Live / Motion Page — Alba Tull V6A
 *
 * Video flip cards managed through Sanity CMS (liveVideo document type).
 * Falls back to placeholder Pexels videos if no Sanity videos exist yet.
 *
 * Team workflow:
 *   1. Go to Sanity Studio → "Live Video" in sidebar
 *   2. Click "+" to create a new video
 *   3. Upload MP4/WebM (or paste an external URL)
 *   4. Add poster image, title, subtitle, flip offset
 *   5. Set displayOrder (lower = appears first) and Published = true
 *   6. Sanity webhook triggers Netlify rebuild (~4 min)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLiveVideos, urlFor, client } from '../lib/sanity.js';

// ── Fetch from Sanity ───────────────────────────────────────────
let sanityVideos = [];
let source = 'fallback';

try {
  const fetched = await getLiveVideos();
  if (fetched && fetched.length > 0) {
    sanityVideos = fetched;
    source = 'sanity';
  }
} catch (e) {
  console.warn('[live] Sanity video fetch failed:', e.message);
}

// ── Resolve video URLs from Sanity data ─────────────────────────
function resolveVideoUrl(v) {
  // Prefer external URL, then Sanity-hosted file
  if (v.videoUrl) return v.videoUrl;
  if (v.videoFile?.asset?._ref) {
    // Build Sanity file URL from asset ref
    // Format: file-{id}-{ext} → https://cdn.sanity.io/files/{projectId}/{dataset}/{id}.{ext}
    const ref = v.videoFile.asset._ref;
    const [, id, ext] = ref.match(/^file-(.+)-(\w+)$/) || [];
    if (id && ext) {
      const projectId = client.config().projectId;
      const dataset = client.config().dataset;
      return `https://cdn.sanity.io/files/${projectId}/${dataset}/${id}.${ext}`;
    }
  }
  return '';
}

function resolvePosterUrl(v) {
  // Prefer external URL, then Sanity-hosted image
  if (v.posterUrl) return v.posterUrl;
  if (v.poster) return urlFor(v.poster).width(900).quality(80).auto('format').url();
  return '';
}

// ── Build final video list ──────────────────────────────────────
let videos = [];

if (source === 'sanity') {
  videos = sanityVideos.map(v => ({
    title:    v.title || 'Untitled',
    subtitle: v.subtitle || '',
    video:    resolveVideoUrl(v),
    poster:   resolvePosterUrl(v),
    offset:   v.flipOffset ?? 4,
  })).filter(v => v.video); // Only include videos with a valid URL
}

// ── Fallback: placeholder Pexels videos ─────────────────────────
if (videos.length === 0) {
  videos = [
    {
      title: 'Botanical',
      subtitle: 'Macro Studies',
      poster: 'https://images.pexels.com/photos/1179229/pexels-photo-1179229.jpeg?auto=compress&w=900',
      video: 'https://videos.pexels.com/video-files/3864103/3864103-hd_1920_1080_30fps.mp4',
      offset: 4
    },
    {
      title: 'Ocean',
      subtitle: 'Tidal Rhythms',
      poster: 'https://images.pexels.com/photos/1295138/pexels-photo-1295138.jpeg?auto=compress&w=900',
      video: 'https://videos.pexels.com/video-files/1390942/1390942-uhd_2732_1440_24fps.mp4',
      offset: 5
    },
    {
      title: 'Urban Flow',
      subtitle: 'City Rhythms',
      poster: 'https://images.pexels.com/photos/1563356/pexels-photo-1563356.jpeg?auto=compress&w=900',
      video: 'https://videos.pexels.com/video-files/5544054/5544054-hd_1920_1080_30fps.mp4',
      offset: 3
    },
    {
      title: 'Natural Light',
      subtitle: 'Golden Hour Series',
      poster: 'https://images.pexels.com/photos/1761279/pexels-photo-1761279.jpeg?auto=compress&w=900',
      video: 'https://videos.pexels.com/video-files/857251/857251-hd_1920_1080_25fps.mp4',
      offset: 4
    },
    {
      title: 'Atmosphere',
      subtitle: 'Mood & Texture',
      poster: 'https://images.pexels.com/photos/1671325/pexels-photo-1671325.jpeg?auto=compress&w=900',
      video: 'https://videos.pexels.com/video-files/856974/856974-hd_1920_1080_30fps.mp4',
      offset: 3
    },
    {
      title: 'Aerial',
      subtitle: 'Above the Terrain',
      poster: 'https://images.pexels.com/photos/1252916/pexels-photo-1252916.jpeg?auto=compress&w=900',
      video: 'https://videos.pexels.com/video-files/1093662/1093662-uhd_2560_1440_30fps.mp4',
      offset: 5
    },
    {
      title: 'Abstract',
      subtitle: 'Color in Movement',
      poster: 'https://images.pexels.com/photos/3075993/pexels-photo-3075993.jpeg?auto=compress&w=900',
      video: 'https://videos.pexels.com/video-files/854669/854669-hd_1920_1080_30fps.mp4',
      offset: 4
    },
    {
      title: 'Golden Hour',
      subtitle: 'Light & Silhouette',
      poster: 'https://images.pexels.com/photos/36717/amazing-animal-beautiful-beautifull.jpg?auto=compress&w=900',
      video: 'https://videos.pexels.com/video-files/2257010/2257010-hd_1920_1080_25fps.mp4',
      offset: 3
    }
  ];
}
---

<BaseLayout title="Live — Alba Tull">
  <div class="live-page">
    <div class="live-header">
      <h1 class="live-title">Motion</h1>
      <p class="live-subtitle">Moving images & live captures</p>
    </div>

    <div class="flip-cards-container">
      {videos.map((v, i) => (
        <div class="flip-card" data-index={i} data-offset={v.offset} data-video-url={v.video}>
          <div class="flip-card-inner">
            <div class="flip-card-front">
              <video poster={v.poster || undefined} muted loop playsinline preload="none"></video>
              <div class="flip-card-label">
                <h2>{v.title}</h2>
                <span>{v.subtitle}</span>
              </div>
            </div>
            <div class="flip-card-back">
              <video poster={v.poster || undefined} muted loop playsinline preload="none"></video>
              <div class="flip-card-label">
                <h2>{v.title}</h2>
                <span>{v.subtitle}</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <script>
    // ═══════════════════════════════════════════════════════════════
    // Flip Card Controller — Lazy Loading + Scroll Flip + Hover/Click
    //
    // Videos start with no src (preload="none"). Three observers:
    //   1. lazyObserver  — loads video src when card is ~1 viewport away,
    //                      unloads when card scrolls far off-screen
    //   2. viewObserver  — plays/pauses videos when in/out of viewport
    //   3. flipObserver  — flips card when it reaches center of viewport
    //
    // This supports 30+ cards without choking page load.
    // ═══════════════════════════════════════════════════════════════

    const cards = document.querySelectorAll('.flip-card');

    // ── Helper: load a card's videos ──────────────────────────────
    function loadCardVideos(card) {
      if (card.dataset.loaded === 'true') return;
      var url = card.dataset.videoUrl;
      if (!url) return;

      var frontVideo = card.querySelector('.flip-card-front video');
      var backVideo = card.querySelector('.flip-card-back video');

      if (frontVideo && !frontVideo.src) {
        frontVideo.src = url;
        frontVideo.preload = 'auto';
        frontVideo.load();
      }
      if (backVideo && !backVideo.src) {
        backVideo.src = url;
        backVideo.preload = 'auto';
        backVideo.load();

        // Set back-video time offset once metadata arrives
        var offset = parseInt(card.dataset.offset) || 4;
        backVideo.addEventListener('loadedmetadata', function() {
          backVideo.currentTime = Math.min(offset, backVideo.duration * 0.4);
        }, { once: true });
      }

      card.dataset.loaded = 'true';
    }

    // ── Helper: unload a card's videos (free memory) ──────────────
    function unloadCardVideos(card) {
      if (card.dataset.loaded !== 'true') return;
      // Don't unload if user is hovering or card is in view
      if (card.dataset.inView === 'true') return;

      var frontVideo = card.querySelector('.flip-card-front video');
      var backVideo = card.querySelector('.flip-card-back video');

      if (frontVideo) {
        frontVideo.pause();
        frontVideo.removeAttribute('src');
        frontVideo.load(); // resets the element, releases buffered data
      }
      if (backVideo) {
        backVideo.pause();
        backVideo.removeAttribute('src');
        backVideo.load();
      }

      card.dataset.loaded = 'false';
    }

    // ── 1. Lazy Load Observer ─────────────────────────────────────
    // Loads videos when card is within ~1 viewport distance.
    // Unloads when card scrolls more than ~2 viewports away.
    var lazyObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          loadCardVideos(entry.target);
        } else {
          // Only unload if truly far away (the large negative rootMargin
          // means this fires when the card is >2 viewports off-screen)
        }
      });
    }, {
      threshold: 0,
      rootMargin: '100% 0px'  // load when within 1 full viewport height
    });

    // Separate observer for unloading — fires when card is far away
    var unloadObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) {
          unloadCardVideos(entry.target);
        }
      });
    }, {
      threshold: 0,
      rootMargin: '200% 0px'  // unload when >2 viewports away
    });

    // ── 2. Viewport Visibility — play/pause ───────────────────────
    var viewObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        var card = entry.target;
        var frontVideo = card.querySelector('.flip-card-front video');
        var backVideo = card.querySelector('.flip-card-back video');

        if (entry.isIntersecting) {
          card.dataset.inView = 'true';
          // Ensure videos are loaded before playing
          loadCardVideos(card);
          if (frontVideo && frontVideo.src) frontVideo.play().catch(function() {});
          if (backVideo && backVideo.src) backVideo.play().catch(function() {});
        } else {
          card.dataset.inView = 'false';
          if (frontVideo) frontVideo.pause();
          if (backVideo) backVideo.pause();
          card.classList.remove('is-flipped');
          card.dataset.scrollFlipped = '';
        }
      });
    }, { threshold: [0, 0.1], rootMargin: '100px 0px' });

    // ── 3. Scroll Flip — flip when card reaches center ────────────
    var flipObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        var card = entry.target;
        if (entry.isIntersecting && entry.intersectionRatio >= 0.35) {
          if (card.dataset.userToggled !== 'true') {
            card.classList.add('is-flipped');
            card.dataset.scrollFlipped = 'true';
          }
        } else if (!entry.isIntersecting || entry.intersectionRatio < 0.15) {
          if (!card.matches(':hover')) {
            card.classList.remove('is-flipped');
            card.dataset.scrollFlipped = '';
            card.dataset.userToggled = '';
          }
        }
      });
    }, { threshold: [0, 0.15, 0.35, 0.6], rootMargin: '-10% 0px -10% 0px' });

    // ── Toggle flip ───────────────────────────────────────────────
    function toggleFlip(card) {
      card.dataset.userToggled = 'true';
      card.classList.toggle('is-flipped');
    }

    // ── Setup each card ───────────────────────────────────────────
    cards.forEach(function(card) {
      lazyObserver.observe(card);
      unloadObserver.observe(card);
      viewObserver.observe(card);
      flipObserver.observe(card);

      card.addEventListener('click', function() { toggleFlip(card); });
      card.addEventListener('mouseenter', function() { toggleFlip(card); });

      card.addEventListener('mouseleave', function() {
        card.dataset.userToggled = '';
        var rect = card.getBoundingClientRect();
        var vh = window.innerHeight;
        var centerY = rect.top + rect.height / 2;
        var isCenter = centerY > vh * 0.3 && centerY < vh * 0.7;
        if (isCenter) {
          card.classList.add('is-flipped');
        } else {
          card.classList.remove('is-flipped');
        }
      });
    });
  </script>
</BaseLayout>
