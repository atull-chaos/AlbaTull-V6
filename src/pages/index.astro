---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchAllWithCache, urlFor } from '../lib/sanity.js';
import { PHOTOS as LOCAL_PHOTOS, getCategories as getLocalCategories, catSlug as makeCatSlug } from '../data/photos.js';

// ── Fetch from Sanity → Cache → Local fallback ──────────────────
let photos = [];
let categories = [];
let featuredPhoto = null;

const { photos: rawPhotos, categories: rawCats, featured: rawFeatured, source } = await fetchAllWithCache();

if ((source === 'sanity' || source === 'cache') && rawPhotos) {
  photos = rawPhotos.map(p => ({
    id:    p._id,
    title: p.title || 'Untitled',
    cat:   p.category?.name || 'Uncategorized',
    catSlug: p.category?.slug || '',
    slug:  p.slug || p._id,
    img:   p.image ? urlFor(p.image).width(600).quality(65).auto('format').url() : '',
    thumb: p.image ? urlFor(p.image).width(200).height(200).fit('crop').quality(55).auto('format').url() : '',
    desc:  p.description || ''
  })).filter(p => p.img);

  categories = (rawCats || []).map(c => ({
    name:  c.name,
    slug:  c.slug,
    count: c.photoCount || 0
  }));

  if (rawFeatured && rawFeatured.image) {
    featuredPhoto = {
      title: rawFeatured.title || 'Untitled',
      cat:   rawFeatured.category?.name || '',
      img:   urlFor(rawFeatured.image).width(800).quality(70).auto('format').url(),
      slug:  rawFeatured.slug || ''
    };
  }
} else {
  photos = LOCAL_PHOTOS.map(p => ({
    ...p,
    thumb: p.img,
    catSlug: makeCatSlug(p.cat)
  }));
  categories = getLocalCategories();
}

// Fallback featured photo
if (!featuredPhoto && photos.length > 0) {
  featuredPhoto = {
    title: photos[0].title,
    cat:   photos[0].cat,
    img:   photos[0].img,
    slug:  photos[0].slug
  };
}

// To override with a local image, uncomment below and save image as public/images/featured.jpg
// featuredPhoto = { title: featuredPhoto?.title || 'Featured', cat: featuredPhoto?.cat || '', img: '/images/featured.jpg', slug: featuredPhoto?.slug || '' };

// Prepare mosaic grid — larger tiles, fewer cells
// Layout: 5 columns × 4 rows = 20 cells, with center cell being the featured photo
// The featured photo will span a 3×2 block in the center
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const shuffledPhotos = shuffle(photos);

// Grid fills viewport — enough cells to cover all breakpoints
// Desktop: 6 cols × 5 rows = 30, Tablet: 4×6 = 24, Mobile: 3×8 = 24
const GRID_CELLS = 30;

// Fill ALL cells with photos (featured overlays via CSS grid placement)
const mosaicPhotos = [];
for (let i = 0; i < GRID_CELLS; i++) {
  mosaicPhotos.push(shuffledPhotos[i % shuffledPhotos.length]);
}

// Featured positions not needed — featured cell is a separate grid item

// All thumbnail URLs for JavaScript to cycle through
const allThumbs = photos.map(p => p.thumb).filter(Boolean);

// Video cells — 3 random positions among the grid cells
const mosaicVideos = [
  'https://videos.pexels.com/video-files/3864103/3864103-hd_1920_1080_30fps.mp4',
  'https://videos.pexels.com/video-files/856974/856974-hd_1920_1080_30fps.mp4',
  'https://videos.pexels.com/video-files/857251/857251-hd_1920_1080_25fps.mp4'
];

const availableForVideo = [];
for (let i = 0; i < GRID_CELLS; i++) {
  availableForVideo.push(i);
}
const videoShuffled = shuffle(availableForVideo);
const videoCellIndices = new Set(videoShuffled.slice(0, mosaicVideos.length));
const videoCellMap = new Map();
let vIdx = 0;
videoCellIndices.forEach(pos => { videoCellMap.set(pos, vIdx++); });
---

<BaseLayout title="Alba Tull - Photography Portfolio">
  <div class="mosaic-fullpage">
    <div class="mosaic-grid-full" id="mosaicGrid">
      {/* Featured photo — separate grid item, positioned via CSS */}
      {featuredPhoto && (
        <div class="mosaic-featured-cell">
          <a href={featuredPhoto.slug ? `/photo/${featuredPhoto.slug}/` : '#'} class="featured-link">
            <img
              src={featuredPhoto.img}
              alt={featuredPhoto.title}
              class="featured-center-img"
            />
            <div class="featured-overlay">
              <div class="featured-label">Featured</div>
              <div class="featured-title">{featuredPhoto.title}</div>
            </div>
          </a>
        </div>
      )}

      {/* All mosaic cells — flip cards: front=muted, back=full color */}
      {mosaicPhotos.map((p, i) => {
        const videoIndex = videoCellMap.get(i);
        const isVideo = videoIndex !== undefined;

        return isVideo ? (
          <a href={`/photo/${p.slug}/`} class="mosaic-cell mosaic-video-cell" data-index={i} data-slug={p.slug}>
            <div class="mosaic-flip-inner">
              <div class="mosaic-face mosaic-face-front">
                <img class="mosaic-img mosaic-current" src={p.thumb} alt={p.title} loading="lazy" />
                <video src={mosaicVideos[videoIndex]} muted loop playsinline autoplay preload="auto"></video>
              </div>
              <div class="mosaic-face mosaic-face-back">
                <img class="mosaic-img" src={p.thumb} alt={p.title} loading="lazy" />
                <video src={mosaicVideos[videoIndex]} muted loop playsinline autoplay preload="auto"></video>
              </div>
            </div>
          </a>
        ) : (
          <a href={`/photo/${p.slug}/`} class="mosaic-cell" data-index={i} data-slug={p.slug}>
            <div class="mosaic-flip-inner">
              <div class="mosaic-face mosaic-face-front">
                <img class="mosaic-img mosaic-current" src={p.thumb} alt={p.title} loading={i < 12 ? 'eager' : 'lazy'} />
                <img class="mosaic-img mosaic-next" src="" alt="" aria-hidden="true" />
              </div>
              <div class="mosaic-face mosaic-face-back">
                <img class="mosaic-img" src={p.img} alt={p.title} loading="lazy" />
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <!-- Branding overlay at bottom -->
    <div class="mosaic-branding">
      <div class="mosaic-brand-name">Alba Tull</div>
      <div class="mosaic-brand-sub">Photography Portfolio of Work (2005—2025)</div>
      <div class="mosaic-brand-meta">
        <span><strong>{photos.length}</strong> Artworks</span>
        <span><strong>{categories.length}</strong> Categories</span>
      </div>
    </div>
  </div>

  <!-- Pass all photo data to JavaScript for cycling -->
  <script define:vars={{ allThumbs, photos }}>
    window.__mosaicThumbs = allThumbs;
    // Map thumbnail URL → slug so crossfade can update href
    window.__thumbToSlug = {};
    // Also map the full-size image URL → slug (fallback)
    photos.forEach(p => {
      if (p.thumb) window.__thumbToSlug[p.thumb] = p.slug;
      if (p.img) window.__thumbToSlug[p.img] = p.slug;
    });
  </script>

  <script>
    // === Photo Mosaic — Flip Cards with Breathing Grid ===
    const thumbs = window.__mosaicThumbs || [];
    if (thumbs.length === 0) {
      document.querySelectorAll('.mosaic-face-front .mosaic-current').forEach(img => {
        if (img.src) thumbs.push(img.src);
      });
    }

    const cells = document.querySelectorAll('.mosaic-cell:not(.mosaic-featured-cell)');
    if (cells.length > 0 && thumbs.length > 2) {
      const cellUrls = new Map();
      cells.forEach(cell => {
        const current = cell.querySelector('.mosaic-face-front .mosaic-current');
        if (current) cellUrls.set(cell, current.src);
      });

      function pickNewUrl(excludeUrl) {
        let attempts = 0;
        let url;
        do {
          url = thumbs[Math.floor(Math.random() * thumbs.length)];
          attempts++;
        } while (url === excludeUrl && attempts < 10);
        return url;
      }

      const thumbToSlug = window.__thumbToSlug || {};

      function crossfadeCell(cell) {
        const front = cell.querySelector('.mosaic-face-front');
        const back = cell.querySelector('.mosaic-face-back');
        if (!front) return;

        const current = front.querySelector('.mosaic-current');
        const next = front.querySelector('.mosaic-next');
        if (!current || !next) return;

        const currentUrl = cellUrls.get(cell) || current.src;
        const newUrl = pickNewUrl(currentUrl);
        cellUrls.set(cell, newUrl);

        next.onload = () => {
          if (cell.tagName === 'A') {
            const slug = thumbToSlug[newUrl];
            if (slug) cell.href = `/photo/${slug}/`;
          }
          // Update back face to match new photo (higher quality version)
          const backImg = back ? back.querySelector('.mosaic-img') : null;
          if (backImg) {
            const fullUrl = newUrl.replace(/w=200&h=200&fit=crop&q=55/, 'w=600&q=65');
            backImg.src = fullUrl;
          }

          next.classList.add('is-visible');
          current.classList.add('is-hidden');
          setTimeout(() => {
            current.src = next.src;
            current.alt = next.alt;
            current.classList.remove('is-hidden');
            next.classList.remove('is-visible');
            next.src = '';
          }, 1600);
        };

        next.alt = '';
        next.src = newUrl;
      }

      // Every 3 seconds, fade 1-2 random cells
      setInterval(() => {
        const count = 1 + Math.floor(Math.random() * 2);
        const indices = new Set();
        while (indices.size < count) {
          indices.add(Math.floor(Math.random() * cells.length));
        }
        indices.forEach(i => crossfadeCell(cells[i]));
      }, 3000);
    }
  </script>
</BaseLayout>
