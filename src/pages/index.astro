---
/**
 * Homepage — Alba Tull V6A
 *
 * Full-viewport mosaic grid with flip cards.
 * - 30 cells (6x5 desktop, 4x6 tablet, 3x8 mobile)
 * - Featured photo overlaid in center
 * - 3–4 cells crossfade to new photos every 2.5s (staggered 400ms apart)
 * - 3 video cells randomly placed
 * - Hover flips to full-quality back face
 * - All timing configurable via MOSAIC_CONFIG
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchAllWithCache, urlFor } from '../lib/sanity.js';
import { PHOTOS as LOCAL_PHOTOS, getCategories as getLocalCategories, catSlug as makeCatSlug } from '../data/photos.js';

// ── Fetch data ──────────────────────────────────────────────────
let photos = [];
let categories = [];
let featuredPhoto = null;

const { photos: rawPhotos, categories: rawCats, featured: rawFeatured, source } = await fetchAllWithCache();

if ((source === 'sanity' || source === 'cache') && rawPhotos) {
  photos = rawPhotos.map(p => ({
    id:      p._id,
    title:   p.title || 'Untitled',
    cat:     p.category?.name || 'Uncategorized',
    catSlug: p.category?.slug || '',
    slug:    p.slug || p._id,
    img:     p.image ? urlFor(p.image).width(800).quality(75).auto('format').url() : '',
    thumb:   p.image ? urlFor(p.image).width(300).height(300).fit('crop').quality(65).auto('format').url() : '',
    desc:    p.description || ''
  })).filter(p => p.img);

  categories = (rawCats || []).map(c => ({
    name:  c.name,
    slug:  c.slug,
    count: c.photoCount || 0
  }));

  if (rawFeatured && rawFeatured.image) {
    featuredPhoto = {
      title: rawFeatured.title || 'Untitled',
      cat:   rawFeatured.category?.name || '',
      img:   urlFor(rawFeatured.image).width(1400).quality(80).auto('format').url(),
      slug:  rawFeatured.slug || ''
    };
  }
} else {
  photos = LOCAL_PHOTOS.map(p => ({ ...p, thumb: p.img, catSlug: makeCatSlug(p.cat) }));
  categories = getLocalCategories();
}

// Fallback featured
if (!featuredPhoto && photos.length > 0) {
  featuredPhoto = { title: photos[0].title, cat: photos[0].cat, img: photos[0].img, slug: photos[0].slug };
}

// ── Mosaic grid setup ───────────────────────────────────────────
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const shuffledPhotos = shuffle(photos);
const GRID_CELLS = 30;

const mosaicPhotos = [];
for (let i = 0; i < GRID_CELLS; i++) {
  mosaicPhotos.push(shuffledPhotos[i % shuffledPhotos.length]);
}

const allThumbs = photos.map(p => p.thumb).filter(Boolean);

// Video cells — 3 random positions
const mosaicVideos = [
  'https://videos.pexels.com/video-files/3864103/3864103-hd_1920_1080_30fps.mp4',
  'https://videos.pexels.com/video-files/856974/856974-hd_1920_1080_30fps.mp4',
  'https://videos.pexels.com/video-files/857251/857251-hd_1920_1080_25fps.mp4'
];

const availablePositions = shuffle(Array.from({ length: GRID_CELLS }, (_, i) => i));
const videoCellIndices = new Set(availablePositions.slice(0, mosaicVideos.length));
const videoCellMap = new Map();
let vIdx = 0;
videoCellIndices.forEach(pos => { videoCellMap.set(pos, vIdx++); });
---

<BaseLayout title="Alba Tull — Photography Portfolio">
  <div class="mosaic-fullpage">
    <div class="mosaic-grid-full" id="mosaicGrid">
      {/* Featured photo — positioned via CSS grid */}
      {featuredPhoto && (
        <div class="mosaic-featured-cell">
          <a href={featuredPhoto.slug ? `/photo/${featuredPhoto.slug}/` : '#'} class="featured-link">
            <img src={featuredPhoto.img} alt={featuredPhoto.title} class="featured-center-img" />
            <div class="featured-overlay">
              <div class="featured-label">Featured</div>
              <div class="featured-title">{featuredPhoto.title}</div>
            </div>
          </a>
        </div>
      )}

      {/* Mosaic cells — flip cards */}
      {mosaicPhotos.map((p, i) => {
        const videoIndex = videoCellMap.get(i);
        const isVideo = videoIndex !== undefined;

        return isVideo ? (
          <div class="mosaic-cell mosaic-video-cell" data-index={i} data-slug={p.slug} data-href={`/photo/${p.slug}/`}>
            <div class="mosaic-flip-inner">
              <div class="mosaic-face mosaic-face-front">
                <img class="mosaic-img mosaic-current" src={p.thumb} alt={p.title} loading="lazy" />
                <video src={mosaicVideos[videoIndex]} muted loop playsinline autoplay preload="auto"></video>
              </div>
              <div class="mosaic-face mosaic-face-back">
                <img class="mosaic-img" src={p.thumb} alt={p.title} loading="lazy" />
                <video src={mosaicVideos[videoIndex]} muted loop playsinline autoplay preload="auto"></video>
              </div>
            </div>
          </div>
        ) : (
          <div class="mosaic-cell" data-index={i} data-slug={p.slug} data-href={`/photo/${p.slug}/`}>
            <div class="mosaic-flip-inner">
              <div class="mosaic-face mosaic-face-front">
                <img class="mosaic-img mosaic-current" src={p.thumb} alt={p.title} loading={i < 12 ? 'eager' : 'lazy'} />
                <img class="mosaic-img mosaic-next" src="" alt="" aria-hidden="true" />
              </div>
              <div class="mosaic-face mosaic-face-back">
                <img class="mosaic-img" src={p.img} alt={p.title} loading="lazy" />
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Branding overlay -->
    <div class="mosaic-branding">
      <div class="mosaic-brand-name">Alba Tull</div>
      <div class="mosaic-brand-sub">Photography Portfolio of Work (2005—2026)</div>
      <div class="mosaic-brand-meta">
        <span><strong>{photos.length}</strong> Artworks</span>
        <span><strong>{categories.length}</strong> Categories</span>
      </div>
    </div>
  </div>

  <!-- Data bridge to JavaScript -->
  <script define:vars={{ allThumbs, photos }}>
    window.__mosaicThumbs = allThumbs;
    window.__thumbToSlug = {};
    photos.forEach(p => {
      if (p.thumb) window.__thumbToSlug[p.thumb] = p.slug;
      if (p.img) window.__thumbToSlug[p.img] = p.slug;
    });
  </script>

  <script>
    // ══════════════════════════════════════════════════════════════
    // Mosaic Crossfade Engine — V6A
    //
    // CONFIGURABLE: Change these constants to adjust behavior.
    // ══════════════════════════════════════════════════════════════
    const MOSAIC_CONFIG = {
      minCells:    3,       // Min cells to crossfade per cycle
      maxCells:    4,       // Max cells to crossfade per cycle
      intervalMs:  3000,    // Base interval between cycles (ms) — was 2500
      staggerMs:   400,     // Stagger delay between each cell (ms)
      fadeDurMs:   1400,    // CSS fade transition duration (ms)
      startDelay:  500,     // Delay before first cycle (ms)
      videoCells:  3        // Number of video cells (informational)
    };

    const thumbs = window.__mosaicThumbs || [];
    if (thumbs.length === 0) {
      document.querySelectorAll('.mosaic-face-front .mosaic-current').forEach(img => {
        if (img.src) thumbs.push(img.src);
      });
    }

    const cells = document.querySelectorAll('.mosaic-cell:not(.mosaic-featured-cell):not(.mosaic-video-cell)');

    if (cells.length > 0 && thumbs.length > 2) {
      const cellUrls = new Map();
      cells.forEach(cell => {
        const current = cell.querySelector('.mosaic-face-front .mosaic-current');
        if (current) cellUrls.set(cell, current.src);
      });

      function pickNewUrl(excludeUrl) {
        let attempts = 0;
        let url;
        do {
          url = thumbs[Math.floor(Math.random() * thumbs.length)];
          attempts++;
        } while (url === excludeUrl && attempts < 10);
        return url;
      }

      const thumbToSlug = window.__thumbToSlug || {};

      function crossfadeCell(cell) {
        const front = cell.querySelector('.mosaic-face-front');
        const back = cell.querySelector('.mosaic-face-back');
        if (!front) return;

        const current = front.querySelector('.mosaic-current');
        const next = front.querySelector('.mosaic-next');
        if (!current || !next) return;

        const currentUrl = cellUrls.get(cell) || current.src;
        const newUrl = pickNewUrl(currentUrl);
        cellUrls.set(cell, newUrl);

        next.onload = () => {
          // Update data-href for JS navigation
          const slug = thumbToSlug[newUrl];
          if (slug) cell.dataset.href = `/photo/${slug}/`;
          // Update back face to higher quality
          const backImg = back ? back.querySelector('.mosaic-img') : null;
          if (backImg) {
            backImg.src = newUrl.replace(/w=200&h=200&fit=crop&q=55/, 'w=600&q=65');
          }

          next.classList.add('is-visible');
          current.classList.add('is-hidden');
          setTimeout(() => {
            current.src = next.src;
            current.alt = next.alt;
            current.classList.remove('is-hidden');
            next.classList.remove('is-visible');
            next.src = '';
          }, MOSAIC_CONFIG.fadeDurMs);
        };

        next.alt = '';
        next.src = newUrl;
      }

      // ── Spatially distributed crossfade ────────────────────────
      // Splits the grid into zones (quadrants) and rotates through
      // them so changes spread across the entire mosaic. Tracks
      // which cells haven't been refreshed yet and prioritizes them.

      // Build a queue of cell indices, shuffled. Once every cell
      // has been hit, reshuffle and start over.
      let refreshQueue = [];
      function refillQueue() {
        refreshQueue = Array.from({ length: cells.length }, (_, i) => i);
        // Fisher-Yates shuffle
        for (let i = refreshQueue.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [refreshQueue[i], refreshQueue[j]] = [refreshQueue[j], refreshQueue[i]];
        }
      }
      refillQueue();

      function runCycle() {
        const count = MOSAIC_CONFIG.minCells +
          Math.floor(Math.random() * (MOSAIC_CONFIG.maxCells - MOSAIC_CONFIG.minCells + 1));

        // Pull from the queue so every cell gets a turn
        const picks = [];
        for (let n = 0; n < count; n++) {
          if (refreshQueue.length === 0) refillQueue();
          picks.push(refreshQueue.pop());
        }

        let delay = 0;
        picks.forEach(i => {
          setTimeout(() => crossfadeCell(cells[i]), delay);
          delay += MOSAIC_CONFIG.staggerMs;
        });
      }

      // Fire the first cycle early, then continue at regular interval
      setTimeout(runCycle, MOSAIC_CONFIG.startDelay);
      setInterval(runCycle, MOSAIC_CONFIG.intervalMs);
    }

    // Mosaic click navigation (uses data-href instead of <a> to avoid URL preview)
    document.addEventListener('click', function(e) {
      var cell = e.target.closest('.mosaic-cell');
      if (cell && cell.dataset.href) {
        window.location.href = cell.dataset.href;
      }
    });
  </script>
</BaseLayout>
